# Maintainer: Peter <your@email.com>
# Modified for local build: /home/ahloi/Scripts/ytm-player
pkgname=ytm-player-git
pkgver=1.5.2.r5.g11840ce
pkgrel=1
pkgdesc="A full-featured YouTube Music TUI client - Rosé Pine Moon Edition"
arch=('any')
url="https://github.com/peternaame-boop/ytm-player"
license=('MIT')
depends=(
    'mpv'
    'python'
    'python-aiosqlite'
    'python-click'
    'python-mpv'
    'python-pillow'
    'python-textual>=7.0'
    'python-ytmusicapi'
    'yt-dlp'
)
makedepends=('git' 'python-build' 'python-installer' 'python-hatchling')
optdepends=(
    'python-anyascii: lyrics transliteration to ASCII'
    'python-dbus-next: MPRIS media key support'
    'python-pylast: Last.fm scrobbling'
    'python-pypresence: Discord Rich Presence'
    'python-spotipy: Spotify playlist import (AUR)'
    'python-thefuzz: Spotify import fuzzy matching (AUR)'
)
provides=('ytm-player')
conflicts=('ytm-player')

# This points to the parent directory (/home/ahloi/Scripts/ytm-player)
source=("ytm-player::git+file:///home/ahloi/Scripts/ytm-player")
sha256sums=('SKIP')

pkgver() {
    cd "$srcdir/ytm-player"
    git describe --long --tags 2>/dev/null | sed 's/^v//;s/\([^-]*-g\)/r\1/;s/-/./g' ||
    printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

build() {
    cd "$srcdir/ytm-player"
    python -m build --wheel --no-isolation
}

package() {
    cd "$srcdir/ytm-player"
    python -m installer --destdir="$pkgdir" dist/*.whl
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
